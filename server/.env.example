# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # set to "production" on Vercel

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=30d

# ─── Swagger (optional) ───────────────────────────────────────────────────────
# Set this on Vercel to point Swagger "Try it out" at your deployed API.
# If left blank, VERCEL_URL (auto-injected by Vercel) is used instead.
# SERVER_URL=https://your-deployment.vercel.app
